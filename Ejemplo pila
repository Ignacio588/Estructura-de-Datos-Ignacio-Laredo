#include <iostream>
#include "Pila.h"
#define MAX 100
using namespace std;

int main()
{
	Pila p;
	int opcion;
	TipoDato elemento;

	do
	{
		cout << "======= MENU PILA =======" << endl;
		cout << "1. Apilar elemento" << endl;
		cout << "2. Desapilar elemento" << endl;
		cout << "3. Ver cima de la pila" << endl;
		cout << "4. Ver pila" << endl;
		cout << "5. Limpiar pila" << endl;
		cout << "6. Verificar si la pila esta vacia" << endl;
		cout << "0. Salir" << endl;
		cout << "Seleccione una opcion" << endl;
		cin >> opcion;

		switch (opcion)
		{
		case 1:
			cout << "Ingresa un elemento: ";
			cin >> elemento;
			if (p.Apilar(elemento))
				cout << "Elemento apilado correctamente" << endl;
			break;

		case 2:
			if (p.Desapilar())
				cout << "Elemento desapilado correctamente." << endl;
			break;

		case 3:
			if (p.CimaPila(elemento))
				cout << "Elemento en la cima: " << elemento << endl;
			break;

		case 4:
			p.VerPila();
			break;

		case 5:
			p.LimpiarPila();
			cout << "La pila fue limpiada." << endl;
			break;

		case 6:
			if (p.PilaVacia())
				cout << "La pila esta vacia." << endl;
			else
				cout << "La pila NO esta vacia. " << endl;
			break;

		case 0:
			cout << "Usted ha salido del programa." << endl;
			break;

		default:
			cout << "Opcion invalida." << endl;
		}
	} while (opcion != 0);
		return 0;
}
	
	
