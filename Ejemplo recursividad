int suma_1(int n) {
    if (n == 1)
        return 1;
    return n + suma_1(n - 1);
}

int horner(int x,int N) {
    if (N == 1)
        return x;
    return pow(x, N) + horner(x, N - 1);
}
int factorial(int n) {
    if ((n == 0) || (n == 1))
        return 1;
    else
        return factorial(n - 1) * n;
}
