// Estructuradedatoslab.cpp : Multiplicación de matrices
//

#include <iostream>
#define MAXCOL 20
#define MAXROW 20

using namespace std;

// Prototipos de funciones
void cargar(int matrix[MAXROW][MAXCOL], int n, int m, char nombre);
void mostrar(int matrix[MAXROW][MAXCOL], int n, int m);
void multiplicar(int A[MAXROW][MAXCOL], int B[MAXROW][MAXCOL], int R[MAXROW][MAXCOL], int r1, int c1, int c2);

int main()
{
    // Definimos las matrices A, B y la de Resultado (R)
    int matrizA[MAXROW][MAXCOL], matrizB[MAXROW][MAXCOL], matrizR[MAXROW][MAXCOL];
    int r1, c1, r2, c2; // Filas y columnas de cada matriz
    int op;

    do {
        cout << "\n******* MENU MULTIPLICACION *******" << endl;
        cout << "1. Configurar y Cargar Matrices (A y B)" << endl;
        cout << "2. Mostrar Matrices" << endl;
        cout << "3. Multiplicar (A x B) y guardar en R" << endl;
        cout << "0. Salir" << endl;
        cout << "Escoja una opcion: ";
        cin >> op;

        switch (op) {
        case 1:
            // Configuración Matriz A
            do {
                cout << "Matriz A - Filas: "; cin >> r1;
                cout << "Matriz A - Columnas: "; cin >> c1;
            } while (r1 <= 0 || r1 > MAXROW || c1 <= 0 || c1 > MAXCOL);
            cargar(matrizA, r1, c1, 'A');

            // Configuración Matriz B
            do {
                cout << "\nNota: Para multiplicar, Matriz B DEBE tener " << c1 << " filas." << endl;
                cout << "Matriz B - Filas: "; cin >> r2;
                cout << "Matriz B - Columnas: "; cin >> c2;
            } while (r2 <= 0 || r2 > MAXROW || c2 <= 0 || c2 > MAXCOL);
            cargar(matrizB, r2, c2, 'B');
            break;

        case 2:
            cout << "\n--- Matriz A ---" << endl;
            mostrar(matrizA, r1, c1);
            cout << "\n--- Matriz B ---" << endl;
            mostrar(matrizB, r2, c2);
            break;

        case 3:
            if (c1 == r2) {
                cout << "Ejecutando multiplicacion..." << endl;
                multiplicar(matrizA, matrizB, matrizR, r1, c1, c2);
                cout << "Resultado Matriz R:" << endl;
                mostrar(matrizR, r1, c2);
            }
            else {
                cout << "ERROR: Las columnas de A (" << c1 << ") no coinciden con filas de B (" << r2 << ")" << endl;
            }
            break;

        case 0:
            cout << "Saliendo..." << endl;
            break;
        }
    } while (op != 0);

    return 0;
}

void cargar(int matrix[MAXROW][MAXCOL], int n, int m, char nombre) {
    cout << "--- Cargando Matriz " << nombre << " ---" << endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cout << nombre << "[" << i + 1 << "][" << j + 1 << "]: ";
            cin >> matrix[i][j];
        }
    }
}

void mostrar(int matrix[MAXROW][MAXCOL], int n, int m) {
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cout << matrix[i][j] << "\t"; // Uso de tabulación para que se vea como tabla
        }
        cout << endl;
    }
}

// Lógica de multiplicación: Fila de A por Columna de B
void multiplicar(int A[MAXROW][MAXCOL], int B[MAXROW][MAXCOL], int R[MAXROW][MAXCOL], int r1, int c1, int c2) {
    // Inicializar matriz R en cero
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) {
            R[i][j] = 0;
            // El tercer bucle 'k' hace la magia de la multiplicación escalar
            for (int k = 0; k < c1; k++) {
                R[i][j] += A[i][k] * B[k][j];
            }
        }
    }
}
